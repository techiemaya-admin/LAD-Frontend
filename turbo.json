{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_API_BASE",
    "NEXT_PUBLIC_BACKEND_URL",
    "NEXT_PUBLIC_WHATSAPP_API_URL",
    "NEXT_PUBLIC_COMMS_SERVICE_URL",
    "NEXT_PUBLIC_SOCKET_URL",
    "NEXT_PUBLIC_ICP_BACKEND_URL",
    "NEXT_PUBLIC_COMMUNITY_API_URL",
    "NEXT_PUBLIC_DISABLE_VAPI"
  ],
  "tasks": {
    "build": {
      "outputs": [".next/**", "dist/**", "lib/**"],
      "cache": true
    },
    "dev": {
      "cache": false
    },
    "lint": {
      "outputs": [],
      "cache": false
    },
    "typecheck": {
      "outputs": [],
      "cache": false
    },
    "test": {
      "outputs": [],
      "cache": false
    }
  }
}
